# =============================================================================
# Chatbot BTP — variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local et adapte les valeurs.

# -----------------------------------------------------------------------------
# LLM Provider — LM Studio (API OpenAI-compatible en local)
# -----------------------------------------------------------------------------
# URL du serveur LM Studio. Démarre LM Studio puis active "Local Server" (port 1234 par défaut).
OPENAI_API_BASE_URL=http://localhost:1234/v1

# Clé API factice — LM Studio ignore la valeur mais le SDK OpenAI en exige une.
OPENAI_API_KEY=lm-studio

# Identifiant du modèle servi par LM Studio. Visible dans LM Studio > Local Server > Loaded model.
# Exemple : "qwen2.5-coder-32b-instruct" ou "mistral-large-instruct".
OPENAI_MODEL=local-model

# -----------------------------------------------------------------------------
# Embeddings (même endpoint LM Studio, modèle séparé chargé en parallèle)
# -----------------------------------------------------------------------------
# Modèle d'embeddings tel que servi par LM Studio.
# Recommandés (multilingues, 1024d) : "text-embedding-bge-m3", "multilingual-e5-large"
EMBEDDING_MODEL=text-embedding-bge-m3

# Dimensions du vecteur produit par le modèle. La table virtuelle corpus_chunks_vec est fixée
# à cette dimension dans lib/db/client.ts. Si tu changes, il faut DROP et recréer cette table.
EMBEDDING_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# Base de données locale (SQLite)
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/app.db

# -----------------------------------------------------------------------------
# Auth.js (à compléter en Phase 2)
# -----------------------------------------------------------------------------
# Génère via : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# -----------------------------------------------------------------------------
# Stripe (optionnel — si non défini, tous les agents sont gratuits en dev)
# -----------------------------------------------------------------------------
# Récupérer depuis https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# Récupérer depuis https://dashboard.stripe.com/test/webhooks (après création de l'endpoint)
# Endpoint à créer : <APP_URL>/api/billing/webhook
# Événements à écouter : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_WEBHOOK_SECRET=whsec_...

# URL publique de l'app (utilisée pour les success/cancel URLs Stripe)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pour activer la facturation, créer les produits dans Stripe et renseigner le
# stripe_price_id dans chaque agents/<slug>/manifest.json.

# -----------------------------------------------------------------------------
# LLM Provider — bascule Anthropic (optionnel)
# -----------------------------------------------------------------------------
# Force le provider pour tous les agents : "lmstudio" (défaut) ou "anthropic".
# Un manifest agent peut aussi override en mettant "model": "claude-sonnet-4-6"
# (tout model commençant par "claude-" route vers Anthropic).
# LLM_PROVIDER=lmstudio

# Clé API Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Modèle Anthropic par défaut quand LLM_PROVIDER=anthropic.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Sentry (optionnel — monitoring d'erreurs)
# -----------------------------------------------------------------------------
# Si vide, Sentry est complètement désactivé (zéro overhead).
# Créer un projet Next.js sur https://sentry.io/ et copier le DSN.
# SENTRY_DSN=https://....ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://....ingest.sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Variables pour l'upload des source-maps en build (CI uniquement).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Géoportail-de-l'urbanisme
# -----------------------------------------------------------------------------
# Aucune variable requise. Le tool `recuperer_plu` interroge apicarto.ign.fr et
# api-adresse.data.gouv.fr (APIs publiques sans clé pour usage modéré).
# Si tu prévois un trafic élevé, demande un quota IGN.
